# Security headers for every response (spec decision #20).
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval' https://static.cloudflareinsights.com; worker-src blob:; child-src blob:; connect-src 'self' blob: https://cloudflareinsights.com; img-src 'self' blob:; style-src 'self'; font-src 'self'; object-src 'none'; base-uri 'none'; form-action 'none'; frame-src 'none'; frame-ancestors 'none'

# Cloudflare Pages reads this file and applies these Cache-Control headers to
# static asset responses. See https://developers.cloudflare.com/pages/configuration/headers/

# Vite fingerprints everything in /assets/* with a content hash — safe forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# 3D models, animations, and geometry fonts are NOT content-hashed: cache for a
# week and revalidate in the background so updates still propagate.
/models/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/animations/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/fonts/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/projects/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/logos/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/icons/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/textures/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# Self-hosted Draco decoder + lighting HDRI — stable, cache a month.
/draco/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400
/hdri/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400
